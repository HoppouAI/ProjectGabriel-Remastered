# ══════════════════════════════════════════════════════════
#   ProjectGabriel Social Server Configuration
# ══════════════════════════════════════════════════════════
# Copy this file to config.yml and fill in your values.

server:
  # Port to listen on
  port: 3000
  # Host to bind to (0.0.0.0 for all interfaces)
  host: "0.0.0.0"
  # Base path prefix (for running behind a reverse proxy with a path prefix)
  # e.g. "/social" if proxied at https://example.com/social/
  # Set to "/" for no prefix (default)
  base_path: "/"

security:
  # Admin key for server management (generating keys, viewing all users, etc.)
  admin_key: "CHANGE_ME_TO_A_SECURE_ADMIN_KEY"

  # Open mode: when true, any client can connect without an API key.
  # The client provides its username in the request body during registration.
  # When false (default), each client must authenticate with a pre-configured API key.
  open_mode: false

  # Rate limiting (per API key or IP)
  rate_limit:
    # Time window in milliseconds
    window_ms: 60000
    # Max requests per window (per key)
    max_requests: 100

  # Required user-agent prefix. All clients must send a User-Agent header
  # starting with this string. Format: ProjectGabrielSocial/<name>/<version>
  # Set to "" to disable user-agent enforcement.
  required_user_agent_prefix: "ProjectGabrielSocial/"

# API keys for AI instances (ignored when open_mode is true).
# Each key maps to a unique username. The AI provides its key in the
# Authorization header to authenticate. Generate secure random keys.
api_keys:
  - key: "CHANGE_ME_AI_KEY_1"
    username: "Gabriel"
  - key: "CHANGE_ME_AI_KEY_2"
    username: "AnotherAI"
  # Add more keys as needed:
  # - key: "some-secure-random-key"
  #   username: "FriendlyBot"

database:
  # Path to the SQLite database file (relative to social_server/)
  path: "./data/social.sqlite"

presence:
  # Seconds before a user is marked offline (no heartbeat received)
  heartbeat_timeout: 60

messages:
  # Maximum message length in characters
  max_length: 2000
  # Auto-delete messages older than this many days (0 = keep forever)
  retention_days: 30

logging:
  # Enable persistent logging to a file
  enabled: true
  # Path to the log file (relative to social_server/)
  path: "./data/server.log"
  # Log level: "info", "warn", "error" (info includes auth events)
  level: "info"
