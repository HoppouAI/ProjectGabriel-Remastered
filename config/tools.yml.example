# config/tools.yml — per-tool / per-plugin-tool toggles
#
# This file is auto-managed. On startup ProjectGabriel walks the live
# tool registry and adds any newly discovered tool here, defaulting it
# to `true`. Existing values are never overwritten, so flipping anything
# off here will stick across upgrades.
#
# Schema:
#   tools:                 # built-in tools shipped with the host
#     <tool_name>: bool
#   plugin_tools:          # tools added by modular plugins, grouped per plugin
#     <plugin_name>:
#       <tool_name>: bool
#
# Note: whether a plugin itself is loaded is controlled by the
# `enabled:` field inside that plugin's own plugins/<name>/plugin.yml,
# NOT by anything in this file. The toggles under plugin_tools.<plugin>
# only decide which of that plugin's tools get exposed to gemini once
# the plugin is loaded. This keeps the "is the plugin alive" decision
# next to the plugin code itself, while the per-tool toggles live here
# alongside everything else the operator can flip.
#
# Example:
#   tools:
#     vrchatJump: false      # disables a single built-in tool
#   plugin_tools:
#     suno:
#       generateSong: false  # plugin still loads, but this tool is hidden

tools: {}
plugin_tools: {}
