# ╔══════════════════════════════════════════════════════════╗
# ║       ProjectGabriel Discord Bot Configuration           ║
# ╚══════════════════════════════════════════════════════════╝
# Copy this file to config.yml and fill in your values.
#
# This bot has its own prompt/append/personality files in discord_bot/prompts/:
#   prompts.yml        -- Named system prompts (copy from prompts.yml.example)
#   appends.yml        -- Auto-appended instructions (copy from appends.yml.example)
#   personalities.yml  -- Switchable personality modes (copy from personalities.yml.example)

# Discord self-bot token (your user account token)
discord_token: "YOUR_DISCORD_TOKEN_HERE"

# User IDs authorized to use admin commands in DMs
# These users can run !status, !reload, !say, etc.
authorized_users:
  - "123456789012345678"
  # - "987654321098765432"

gemini:
  # Primary API key (required) - get from https://aistudio.google.com/apikey
  api_key: "YOUR_GEMINI_API_KEY_HERE"

  # Backup keys for automatic rotation when rate limited (optional)
  # The system will cycle through these when the primary key hits quota limits
  backup_keys: []
  #  - "BACKUP_KEY_1"
  #  - "BACKUP_KEY_2"

  # Gemini Live model
  # Supports both 2.5 and 3.1 Live models:
  #   2.5: gemini-2.5-flash-native-audio-preview-12-2025 (native audio, affective)
  #   3.1: gemini-3.1-flash-live-001 (thinking_level, realtime text input)
  model: "gemini-2.5-flash-native-audio-preview-09-2025"

  # System prompt -- select a named prompt from config/prompts/prompts.yml
  # The prompt system, appends, and personalities are shared with the main AI.
  prompt: "normal"

  # Fallback system prompt (used only if the named prompt above is not found)
  system_prompt: |
    You are a friendly AI chatting on Discord. You respond naturally and in-character
    like a real person would. Keep responses concise and conversational -- Discord
    messages should feel human, not robotic. Use casual language, emojis when
    appropriate, and match the energy of whoever you're talking to.

  # ── Voice Configuration ──
  # Prebuilt voice for the Live session's audio (transcription is captured for text).
  # Available voices: Puck, Charon, Kore, Fenrir, Aoede, Leda, Orus, Zephyr
  voice: "Puck"

  # ── Generation Parameters ──
  temperature: 1.0     # 0.0-2.0, controls randomness (default: 1.0, higher = more creative)
  top_p: null          # Nucleus sampling threshold (null = model default)
  top_k: null          # Top-k sampling (null = model default)
  max_output_tokens: 1024  # Max tokens per response

  # ── Thinking Configuration ──
  # Enables the model to "think" before responding (inner monologue).
  thinking:
    # For 2.5 models: thinking token budget (int, higher = more thorough, 0 = disable)
    budget: 2048
    # For 3.1 models: thinking level (minimal / low / medium / high)
    # Ignored on 2.5 models. Set budget to null when using a 3.1 model.
    level: null
    # Whether to include thought summaries in logs.
    include_thoughts: false

  # ── Context Window Compression ──
  # Prevents session termination when context gets too large.
  context_window_compression:
    enabled: true
    # Token count that triggers compression (null = 80% of model's context window)
    trigger_tokens: 100000
    # Tokens to keep after compression (null = trigger_tokens / 2)
    target_tokens: 50000

# ══════════════════════════════════════════════════════════
# Bot Behavior
# ══════════════════════════════════════════════════════════
behavior:
  # Auto-respond to DMs from anyone (not just authorized users)
  auto_respond_dms: true

  # In servers, the bot responds ONLY when:
  #   1. Someone @mentions you
  #   2. Someone replies to one of your messages

  # Typing indicator delay in ms (simulates reading before responding)
  typing_delay_ms: 1500

  # Batch window in ms -- when multiple messages arrive rapidly in the same channel,
  # they are combined into a single prompt. This is how long to wait for more messages
  # before processing the batch. Higher = more messages combined, but slower response.
  batch_window_ms: 3000

  # Max Discord message length before splitting into multiple messages
  max_message_length: 2000

  # Minimum seconds between responses in the same channel (rate limiting)
  response_cooldown: 2.0

  # Show "reconnecting..." message in chat when session handle is cleared after bad responses
  show_reconnecting: false

  # How many recent messages to include as context when responding
  context_message_count: 15

# ══════════════════════════════════════════════════════════
# Persistent Memory System
# ══════════════════════════════════════════════════════════
# Uses the main ProjectGabriel memory system (shared database).
memory:
  enabled: true

  # Prefix for Discord bot memory keys to distinguish from VRChat memories
  key_prefix: "discord_"

  # How many recent memories to include in the system prompt
  prompt_memory_count: 10

# ══════════════════════════════════════════════════════════
# VRChat Relay
# ══════════════════════════════════════════════════════════
# Relay messages back to the main VRChat Gemini Live session.
# The Discord bot can forward important info/requests to VRChat.
relay:
  enabled: true

# ══════════════════════════════════════════════════════════
# Conversation Logging
# ══════════════════════════════════════════════════════════
# Per-channel conversation history saved to JSON files.
conversations:
  enabled: true
  save_dir: "discord_bot/data/conversations"

# ══════════════════════════════════════════════════════════
# Embed Webhook
# ══════════════════════════════════════════════════════════
# Webhook URL used to render rich embeds for admin commands.
# Create a webhook in a private channel, paste the URL here.
# The bot will post embeds via the webhook, then forward them
# to the channel where the admin command was run.
# Leave empty to use plain text for admin command output.
embed_webhook_url: ""

# Logging level: DEBUG, INFO, WARNING, ERROR
log_level: "INFO"
